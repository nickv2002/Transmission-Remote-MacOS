<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Base Info.plist. The remaining keys (bundle id, icon, principal class, etc.)
	  are generated from INFOPLIST_KEY_* in project.yml and merged in by Xcode
	  (GENERATE_INFOPLIST_FILE = YES). This file exists only to declare that we
	  open .torrent documents, which has no INFOPLIST_KEY_ equivalent.
	-->
	<key>SUFeedURL</key>
	<string>https://raw.githubusercontent.com/nickv2002/Transmission-Remote-MacOS/main/appcast.xml</string>
	<!--
	  Ed25519 public key generated by `generate_keys` (from `brew install sparkle`).
	  The matching private key lives in the login Keychain ("Sparkle Ed25519 Private Key")
	  and is used by `sign_update` in scripts/release.sh. Never commit the private key.
	  Run `generate_keys` once per machine; paste the printed base64 string below.
	-->
	<key>SUPublicEDKey</key>
	<string>+ONkpmgvNWrF3vZIpoBPehwCK9SH4FgKELrAkXpvUgQ=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>CFBundleIconFile</key>
	<string>AppIcon</string>
	<!--
	  App Transport Security: this app talks to a self-hosted Transmission daemon,
	  typically over plain HTTP on a LAN or VPN (e.g. 10.0.1.2, n5.local, a
	  Tailscale host). ATS blocks cleartext HTTP to named hosts by default, so a
	  hostname like "n5.local" would fail where the bare IP works. Allow arbitrary
	  loads so any user-entered host works over HTTP; HTTPS hosts (e.g. Tailscale
	  with a valid cert) still validate normally.
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>BitTorrent Document</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>org.bittorrent.torrent</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
