#################################################################################
#
#  Assemble the source RPM for lighterowl's version of transgui and submit it for
#  building to my transgui COPR project ->
#  https://copr.fedorainfracloud.org/coprs/dlk/transgui
#
#################################################################################

set -e

FORKURL="https://raw.githubusercontent.com/dlk3/transgui/refs/heads/copr/build/fedora"

#  Fetch the SPEC file from my fork of lighterowl's transgui repo
curl -L -o ${HOME}/rpmbuild/SPECS/transgui.spec "${FORKURL}/transgui.spec"

#  Fetch lighterowl's transgui source 
cd /tmp
TRANSGUI_VERSION=$(awk '/^Version:/ {print $2}' ${HOME}/rpmbuild/SPECS/transgui.spec)
rm -fr transgui-${TRANSGUI_VERSION}
git clone --depth 1 --branch v${TRANSGUI_VERSION} --recurse-submodules https://github.com/lighterowl/transgui.git transgui-${TRANSGUI_VERSION}

#  Fetch the transgui.desktop file and transgui.png icon from my fork of 
#  lighterowl's transgui repo
curl -L -o transgui-${TRANSGUI_VERSION}/transgui.desktop "$FORKURL/transgui.desktop"
curl -L -o transgui-${TRANSGUI_VERSION}/transgui.png "$FORKURL/transgui.png"

#  Create the source tar.gz
rm -f ${HOME}/rpmbuild/SOURCES/transgui-${TRANSGUI_VERSION}.tar.gz
tar czf ${HOME}/rpmbuild/SOURCES/transgui-${TRANSGUI_VERSION}.tar.gz transgui-${TRANSGUI_VERSION}
	
#  Build the package file
rm -f ${HOME}/rpmbuild/SRPMS/transgui-${TRANSGUI_VERSION}-*.src.rpm
rm -f ${HOME}/rpmbuild/RPMS//x86_64/transgui-${TRANSGUI_VERSION}-*.rpm
rpmbuild -bs ${HOME}/rpmbuild/SPECS/transgui.spec
#  Build locally for testing
#rpmbuild -ba ${HOME}/rpmbuild/SPECS/transgui.spec

#  Submit to COPR
copr-cli build transgui ${HOME}/rpmbuild/SRPMS/transgui-${TRANSGUI_VERSION}-*.src.rpm
